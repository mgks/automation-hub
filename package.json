{
  "name": "automation-hub",
  "version": "1.0.0",
  "description": "The universal, searchable, and hosted directory for automation workflows across n8n, OpenClaw, and more.",
  "main": "generator/build.js",
  "scripts": {
    "clean": "bun -e \"require('fs-extra').removeSync('./docs'); require('fs-extra').removeSync('./tmp');\"",
    "build": "npm run clean && bun generator/build.js",
    "dev": "npm run build && bun x http-server docs",
    "update:n8n": "bun generator/providers/n8n.js",
    "update:openclaw": "bun generator/providers/openclaw.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgks/n8n.git"
  },
  "author": "mgks",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mgks/n8n/issues"
  },
  "homepage": "https://github.com/mgks/n8n#readme",
  "dependencies": {
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.0.0",
    "simple-git": "^3.25.0",
    "sitemap": "^8.0.0"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
